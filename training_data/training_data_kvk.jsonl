{"messages":[{"role":"user","content":"Write a decision function review_decision that returns approve, revise, or abort based on review and retry count."},{"role":"assistant","content":"def review_decision(state: FileAgentState) -> Literal[\\\"approve\\\", \\\"revise\\\", \\\"abort\\\"]:\\n    review = state.get(\\\"review\\\")\\n    if not review:\\n        return \\\"revise\\\"\\n\\n    retry_count = dict(state.get(\\\"retry_count\\\") or {})\\n    current_count = retry_count.get(\\\"review\\\", 0)\\n\\n    if review.get(\\\"status\\\", \\\"\\\").lower() == \\\"approved\\\":\\n        return \\\"approve\\\"\\n\\n    if current_count >= MAX_REVIEW_RETRIES:\\n        return \\\"abort\\\"\\n\\n    return \\\"revise\\\""}]}
