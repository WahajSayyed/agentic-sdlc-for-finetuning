{"messages":[{"role":"user","content":"Write a function extract_plan_node that parses JSON from the last LLM message and returns a structured plan."},{"role":"assistant","content":"def extract_plan_node(state: AgentState):\\n    \\\"\\\"\\\"\\n    Parse the planner's final JSON response into structured Plan.\\n\\n    Returns:\\n        dict:\\n            {\\\"plan\\\": parsed_plan_dict}\\n\\n    Behavior:\\n        - Handles markdown-wrapped JSON (```json ... ```)\\n        - Falls back gracefully if JSON parsing fails\\n    \\\"\\\"\\\"\\n\\n    logger.debug(f\\\"Received STATE:\\\\n{state}\\\")\\n    logger.info(\\\"Starting EXTRACT PLAN Node\\\")\\n\\n    last_message = state[\\\"messages\\\"][-1]\\n    content = last_message.content\\n\\n    if \\\"```json\\\" in content:\\n        content = content.split(\\\"```json\\\")[1].split(\\\"```\\\")[0]\\n    elif \\\"```\\\" in content:\\n        content = content.split(\\\"```\\\")[1].split(\\\"```\\\")[0]\\n\\n    try:\\n        plan = json.loads(content.strip())\\n    except json.JSONDecodeError:\\n        plan = {\\n            \\\"task_description\\\": content,\\n            \\\"files_to_read\\\": [],\\n            \\\"files_to_edit\\\": [],\\n            \\\"steps\\\": [content]\\n        }\\n\\n    return {\\\"plan\\\": plan}"}]}
