# ─────────────────────────────────────────────────────────────
# .env.docker
# Environment variables for Docker Compose.
# These OVERRIDE .env values — do not commit real secrets.
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME=Agentic_SDLC
APP_ENV=development
DEBUG=true

# Paths (inside the container, not your host machine)
WORKING_DIR=/app/output
LOG_DIR=/app/logs
DATA_DIR=/app/data

# Server (0.0.0.0 means "listen on all interfaces" inside Docker)
HOST=0.0.0.0
PORT=8000

# Database
# IMPORTANT: host is "db" — the Docker Compose service name, not localhost
DB_TYPE=postgresql
DB_DRIVER=asyncpg
DB_HOST=db
DB_PORT=5432
DB_NAME=agentic_sdlc
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/agentic_sdlc



# Anthropic (replace with your real key)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (replace with your real key)
OPENAI_API_KEY=sk-ant-your-key-here

# LLM CONFIG 
# BASE_URL = "http://localhost:8080/v1"
BASE_URL = "http://<YOUR_WSL2_IP>:8080/v1"
MODEL = "Qwen2.5-7B-Instruct.Q4_0.gguf"
API_KEY = OPENAI_API_KEY

# Retry Counts
MAX_REVIEW_RETRIES=1
MAX_STATIC_CHECK_RETRIES=2

# Redis (for Celery — Phase 2, defined now so it's ready)
REDIS_URL=redis://redis:6379/0

NEXT_PUBLIC_API_URL=http://<YOUR_WSL2_IP>:8000