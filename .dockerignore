# ─────────────────────────────────────────────────────────────
# .dockerignore (project root)
# Files excluded from the Docker build context.
# Smaller context = faster builds.
# ─────────────────────────────────────────────────────────────

# Git
.git/
.gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
tests/

# Logs and output (mounted as volumes instead)
logs/
output/
data/

# Environment files (injected via docker-compose env_file)
.env
.env.*
!.env.docker

# Frontend (handled by Dockerfile.ui)
ui/node_modules/
ui/.next/

# IDE
.vscode/
.idea/
*.swp

# Docker files themselves
Dockerfile*
docker-compose*.yml
