# Application
APP_NAME=agentic-sdlc
APP_ENV=development
DEBUG=true

# Paths
WORKING_DIR=/tmp/output  # ~/agentic-sdlc/output
LOG_DIR=/tmp/logs # ~/agentic-sdlc/logs
DATA_DIR=/tmp/data # ~/agentic-sdlc/data

# Server
HOST=127.0.0.1
PORT=5000

# Database
DB_TYPE=postgresql
DB_DRIVER=asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentic_sdlc
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_sdlc

# Retry Counts
MAX_REVIEW_RETRIES = 3
MAX_STATIC_CHECK_RETRIES = 3

REDIS_URL=redis://localhost:6379/0